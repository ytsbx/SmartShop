# ============================================================================
# SmartShop v2.0 — 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并填入真实值:
#   cp .env.example .env
# Docker Compose 会自动读取 .env 文件
# ============================================================================

# ---- 大模型 (DeepSeek, 兼容 OpenAI 接口) ----
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---- MySQL 数据库 ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=smartshop
# Docker Compose 用（MySQL root 密码）
MYSQL_ROOT_PASSWORD=smartshop123

# ---- 端口（可选，默认值如下）----
# A2A_ROUTER_PORT=8008
# PRODUCT_MCP_PORT=8100
# ORDER_MCP_PORT=8101
# STREAMLIT_PORT=8502
